<view class="page stack">
  <view class="card stack">
    <view class="title">加入婚礼</view>
    <input
      class="input"
      placeholder="请输入 6 位数字婚礼 ID"
      value="{{shortId}}"
      maxlength="6"
      bindinput="onShortIdInput"
    />
    <view wx:if="{{error}}" class="error">{{error}}</view>
    <view class="row">
      <button class="button button-secondary" loading="{{previewLoading}}" bindtap="previewWedding">查询</button>
      <button class="button button-primary" loading="{{loading}}" bindtap="joinWedding">加入</button>
    </view>
  </view>

  <view wx:if="{{wedding}}" class="card stack">
    <view class="section-title">婚礼信息</view>
    <view>名称：{{wedding.name}}</view>
    <view class="muted">婚礼日期：{{wedding.weddingDate.slice(0, 10)}}</view>
    <view class="muted">创建人：{{wedding.creatorName}}</view>
  </view>
</view>
