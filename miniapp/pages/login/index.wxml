<view class="page">
  <view class="card stack">
    <view>
      <view class="title">登录婚礼协作</view>
      <view class="subtitle">使用现有账号进入婚礼筹备与当天安排</view>
    </view>

    <view wx:if="{{error}}" class="error">{{error}}</view>

    <input
      class="input"
      placeholder="用户名"
      value="{{username}}"
      bindinput="onUsernameInput"
    />

    <input
      class="input"
      password
      placeholder="密码"
      value="{{password}}"
      bindinput="onPasswordInput"
    />

    <button
      class="button button-primary"
      loading="{{loading}}"
      bindtap="handleLogin"
    >
      登录
    </button>
  </view>
</view>
