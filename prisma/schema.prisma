// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String?  @unique
  displayName String?
  phone     String?  @unique
  wechatOpenId String? @unique
  passwordHash String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  createdWeddings     Wedding[]            @relation("WeddingCreator")
  weddingParticipants WeddingParticipant[]
  assignedTasks       Task[]
  sessions            Session[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  clientType String   @default("WEB") // "WEB" or "MINIAPP"
  expiresAt DateTime
  createdAt DateTime @default(now())
  lastAccessAt DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([token])
  @@index([userId])
}

model Wedding {
  id          String   @id @default(cuid())
  shortId     String   @unique // 6位短ID，用于邀请
  name        String
  weddingDate DateTime
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  creator      User                 @relation("WeddingCreator", fields: [createdById], references: [id], onDelete: Cascade)
  participants WeddingParticipant[]
  tasks        Task[]
  
  @@index([shortId])
}

model WeddingParticipant {
  id        String   @id @default(cuid())
  weddingId String
  userId    String
  role      String   // "OWNER" or "PARTICIPANT"
  createdAt DateTime @default(now())
  
  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([weddingId, userId])
  @@index([weddingId])
  @@index([userId])
}

model Task {
  id            String   @id @default(cuid())
  weddingId     String
  title         String
  description   String?
  owner         String   // 负责人名称（如"巩"、"陆"、"一起"）
  assignedUserId String? // 分配给的用户ID（可选）
  status        String   @default("PENDING") // "PENDING", "IN_PROGRESS", "COMPLETED"
  phase         String   @default("PREPARATION") // "PREPARATION" or "WEDDING_DAY"
  timeFrame     String   // 时间段（如"5个月"、"3个月"、"3周"、"1周"、"当天"）
  scheduledAt   DateTime?
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  wedding       Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  assignedUser  User?    @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)
  
  @@index([weddingId])
  @@index([weddingId, status])
  @@index([weddingId, phase, sortOrder])
  @@index([weddingId, scheduledAt])
  @@index([assignedUserId])
}
